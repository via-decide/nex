# Nex Deep Research Engine — Environment Variables

# Required: Anthropic API key for LLM-powered modules
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Zayvora integration
ZAYVORA_ENDPOINT=https://api.zayvora.io
ZAYVORA_API_KEY=your_zayvora_api_key_here

# Server config
PORT=8000
HOST=0.0.0.0

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
